@model List<ExpenseTracker.Models.Ausgabe>

@{
    ViewData["Title"] = "Ausgaben";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Ausgaben</h1>

    <a asp-action="Create" class="btn btn-primary">
        Neue Ausgabe
    </a>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }
</div>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Datum</th>
        <th>Ausgabe</th>
        <th>Kategorie</th>
        <th>Zahlungsart</th>
        <th class="text-end">Betrag</th>
        <th class="text-center">Aktionen</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var ausgabe in Model)
    {
        <tr>
            <td>@ausgabe.Datum.ToString("dd.MM.yyyy")</td>
            <td>
                <strong>@ausgabe.Bezeichnung</strong>

                @if (!string.IsNullOrWhiteSpace(ausgabe.Beschreibung))
                {
                    <br />
                    <small class="text-muted">
                        @ausgabe.Beschreibung
                    </small>
                }
            </td>
            <td>@ausgabe.Kategorie?.Name</td>
            <td>@ausgabe.Zahlungsart?.Name</td>
            <td class="text-end">@ausgabe.Betrag.ToString("C")</td>
            <td class="text-center">
                <a asp-action="Edit"
                   asp-route-id="@ausgabe.AusgabeID"
                   class="btn btn-sm btn-outline-primary">
                    Bearbeiten
                </a>

                <a asp-action="Delete"
                   asp-route-id="@ausgabe.AusgabeID"
                   class="btn btn-sm btn-outline-danger">
                    Löschen
                </a>
            </td>
        </tr>
    }
    </tbody>
</table>